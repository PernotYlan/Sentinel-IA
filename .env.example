REDIS_HOST=10.0.0.1 # VM's WireGuard IP
REDIS_PORT=6379 # Redis port, default 6379
REDIS_PASSWORD=password # Redis auth password
REDIS_KEY=received:client:info # Specific List key this client's data is pushed to
CLIENT_ID=client_A # human readable identifier for this client, used in reports/logs

PG_HOST=10.0.0.2 # PostgreSQL host
PG_PORT=5432 # PostgreSQL port, default 5432
PG_DB=sentinel # Database name
PG_USER=sentinel # PostgreSQL user
PG_PASSWORD=password # PostgreSQL password

LOG_LEVEL=INFO # Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_FILE=sentinel.log # Log file path, uses RotatingFileHandler (default: sentinel.log)

IF_CONTAMINATION=0.01 # Isolation Forest contamination rate (default: 0.01). Lower = fewer false positives. Tune with SOC.
IF_TRAIN_THRESHOLD=30000 # Number of events required before first IF training (default: 30000)
N_WORKERS=3 # Number of worker processes for XGBoost + Autoencoder (default: 3)
